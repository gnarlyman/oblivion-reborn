<image name="boss_health">
	<visible> &false; </visible>
	<filename> Textures\Menus\ExUI\boss_bar_empty.dds </filename>
	<width> 1024 </width>
	<height> 32 </height>
	<x>
		<copy src="screen()" trait="width"/>
		<sub> 1024 </sub>
		<div> 2 </div>
	</x>
	<y> 
		<copy src="screen()" trait="height" />
		<mul> 0.05 </mul>
	</y>
	<user0> 1 </user0>
	<image name="boss_health_bar">
		<filename> Textures\Menus\ExUI\boss_bar_full.dds </filename>
		<depth> 1 </depth>
		<width>
			<copy src="boss_health" trait="width"/>
			<mul> <copy src="boss_health" trait="user0"/> </mul>
		</width>
		<height> 32 </height>
		<x> <copy src="boss_health" trait="x"/> </x>
		<y> <copy src="boss_health" trait="y"/> </y>
	</image>
	<text name="boss_name">
		<depth> 4 </depth>
		<string> Boss Name </string>
		<font> 3 </font>			
		<red> 200 </red>
		<green> 175 </green>
		<blue> 125  </blue>
		<alpha> 255 </alpha>
		<wrapwidth> 480 </wrapwidth>
		<justify> &center; </justify>
		<x>
			<copy src="boss_health" trait="x"/>
			<add>
				<copy src="boss_health" trait="width"/>
				<div> 2 </div>
			</add>
		</x>
		<y>
			<copy src="boss_health" trait="y"/>
			<add> 20 </add>
		</y>
	</text>
	<text name="boss_name_shd">
		<font> 3 </font>
		<string> <copy src="boss_name" trait="string" /> </string>
		<depth> 1 </depth>
		<wrapwidth> 480 </wrapwidth>
		<justify> &center; </justify>
		<x>
			<copy src="boss_name" trait="x" />
			<add> 1.4 </add>
		</x>
		<y>
			<copy src="boss_name" trait="y" />
			<add> 1 </add>
		</y>
		<red> 0 </red>
		<green> 0 </green>
		<blue> 0 </blue>
		<alpha> 200 </alpha>
	</text>
</image>

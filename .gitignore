# ─── Reproducible content: excluded (fetched by Wabbajack at install time) ───

# Mod contents: keep only meta.ini (Nexus mod ID + version lock)
mods/*/*
!mods/*/meta.ini

# Local patch mods: no Nexus source, so their content must live in git
!mods/MIEO - Parasol Mesh Fix/**
!mods/Extended UI - Boss Bar Position Fix/**
!mods/Reborn Configs/**
!mods/Reborn - OOO Unofficial Patch CR/**

# Archives: keep only .meta files (Nexus fileID + download source)
downloads/*
!downloads/*.meta

# Vanilla Oblivion game files
Stock Game/

# ─── MO2 runtime: reproducible by reinstalling MO2 portable ───
# Anchored to repo root so they don't match nested dirs in mod folders
# (e.g. mods/Reborn Configs/OBSE/Plugins/).
/plugins/
/stylesheets/
/translations/
/qml/
/dlls/
/tutorials/
/resources/
/loot/
/explorer++/
/styles/
/platforms/
/licenses/
/webcache/

# MO2 binaries at root
ModOrganizer.exe
QtWebEngineProcess.exe
helper.exe
nxmhandler.exe
usvfs_proxy_x64.exe
usvfs_proxy_x86.exe
usvfs_x64.dll
usvfs_x86.dll
libcrypto-3-x64.dll
libssl-3-x64.dll
uibase.dll
splash.png
dump_running_process.bat

# MO2 Nexus-category cache (regenerated on launch)
/categories.dat
/nexuscatmap.dat

# ─── Ephemeral / runtime ───
logs/
crashDumps/
overwrite/
__temp__/
*.log
*.tmp
*.bak
*.before_*
__pycache__/

# xEdit per-user view settings (per-profile runtime state)
profiles/*/plugins.tes4viewsettings
profiles/*/plugins.fo4viewsettings

# Per-profile save games (too big, user-specific)
profiles/*/saves/

# Wrye Bash runtime state (Bash Installers + Bash Mod Data Table.dat)
Oblivion Mods/

# ─── Build artifacts ───
# .wabbajack compiled output goes to GitHub Releases, not the repo
*.wabbajack

# ─── .NET build artifacts (research/usvfs-poc/UsvfsLauncher) ───
research/usvfs-poc/**/bin/
research/usvfs-poc/**/obj/
# Validation output artifacts (regenerable by re-running the launcher)
research/usvfs-poc/*.json

# ─── REPL daemon runtime + scratch probe outputs ───
# Daemon control directories (job submit/done queue + logs)
research/.repl-daemon*/
# One-shot probe stdout/stderr captures
research/repl-*.out
research/repl-*.err
research/repl-smoke.txt
# oblivion-conflicts sweep one-shot outputs
research/v0*-smoke.*
research/v0*-conflicts-smoke.*

# ─── merge-probes workspace runtime ───
# Test-fixture ESPs and xEdit cache (regenerable by re-running probe scripts)
research/merge-probes/data/
# xEdit load-order/view state captured during probe runs
research/merge-probes/loadorder_*.txt
research/merge-probes/loadorder_*.tes4viewsettings
research/merge-probes/loadorder_*.fo4viewsettings

# ─── Ghidra project runtime (binary DB files; regenerable from .exe) ───
# Keep .gpr metadata + decompiled .c/.h + per-segment exports + scripts; drop the binary DB.
research/ghidra-projects/**/*.gbf
research/ghidra-projects/**/*.bak
research/ghidra-projects/Oblivion.rep/idata/00/~00000000.db/

# ─── Secrets ───
# Nexus API key etc. — never commit
.env
*.env
!*.env.template

# ─── Worktrees (subagent-driven dev) ───
_worktrees/
